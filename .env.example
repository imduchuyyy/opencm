# OpenCM Environment Configuration
# Copy to .env and fill in your values

# Bot token (create via @BotFather on Telegram)
BOT_TOKEN=

# Database path (default: opencm.db)
DATABASE_PATH=opencm.db

# Default OpenAI model for new groups
DEFAULT_MODEL=gpt-4o

# OpenAI API Key (required)
OPENAI_API_KEY=

# LangSearch API Key (for web search tool, free - get at https://langsearch.com/dashboard)
LANGSEARCH_API_KEY=
