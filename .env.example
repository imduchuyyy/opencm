# OpenCM Environment Configuration
# Copy to .env and fill in your values

# Master bot token (create via @BotFather on Telegram)
MASTER_BOT_TOKEN=

# Database path (default: opencm.db)
DATABASE_PATH=opencm.db

# Default OpenAI model for new agents
DEFAULT_MODEL=gpt-4o

# OpenAI API Key (required)
OPENAI_API_KEY=
